AGENTHUB_ENV=local
AGENTHUB_APP_NAME=AgentHub Backend
AGENTHUB_API_PREFIX=/api/v1

AGENTHUB_DB_URL=sqlite:///./agenthub.db
AGENTHUB_RESET_DB_ON_STARTUP=false

AGENTHUB_DATA_ROOT=~/.multiproj-agent
AGENTHUB_SKILL_POOL_DIR=./skill-pool

AGENTHUB_CORS_ORIGINS=["http://127.0.0.1:5173","http://localhost:5173"]

AGENTHUB_JWT_SECRET_KEY=replace-with-a-random-secret-at-least-32-chars
AGENTHUB_JWT_ALGORITHM=HS256
AGENTHUB_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

AGENTHUB_OPENAI_API_KEY=your_key
AGENTHUB_OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AGENTHUB_OPENAI_MODEL=qwen3.6-plus
AGENTHUB_DEFAULT_AI_SYSTEM_PROMPT=You are a helpful AI assistant.

AGENTHUB_PROJECT_COMMAND_TIMEOUT_SECONDS=120
AGENTHUB_EXECUTION_COMMAND_TIMEOUT_SECONDS=600
AGENTHUB_DEPLOYMENT_COMMAND_TIMEOUT_SECONDS=1800

AGENTHUB_AI_SHORT_TERM_HISTORY_LIMIT=50
AGENTHUB_MEMORY_COMPRESS_TRIGGER_TOKENS=3500
AGENTHUB_MEMORY_COMPRESS_KEEP_RECENT_MESSAGES=12

AGENTHUB_MESSAGE_EVENT_RECOVERY_ENABLED=true
AGENTHUB_MESSAGE_EVENT_RECOVERY_INTERVAL_SECONDS=2.0
AGENTHUB_MESSAGE_EVENT_RECOVERY_BATCH_SIZE=32

AGENTHUB_MANAGER_REACT_MAX_ITERS=60
AGENTHUB_AGENT_REACT_MAX_ITERS=40

AGENTHUB_ACP_CODEX_COMMAND=npx -y @zed-industries/codex-acp
AGENTHUB_ACP_CLAUDE_COMMAND=python -m claude_code_acp

AGENTHUB_DOCKER_SANDBOX_DEFAULT_IMAGE=node:20-bookworm
AGENTHUB_DOCKER_SANDBOX_MEMORY_LIMIT=2g
AGENTHUB_DOCKER_SANDBOX_CPU_LIMIT=2.0

AGENTHUB_COMMAND_OUTPUT_LIMIT_CHARS=50000
